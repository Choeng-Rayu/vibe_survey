# Application
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/vibe_survey?connection_limit=10&pool_timeout=20"
DIRECT_URL="postgresql://user:password@localhost:5432/vibe_survey"

# Redis
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-secret-key-change-in-production"
JWT_REFRESH_SECRET="your-refresh-secret-key-change-in-production"
JWT_ACCESS_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# Encryption
ENCRYPTION_KEY="your-encryption-key-32-characters"

# AI (NVIDIA)
NVIDIA_API_KEY="your-nvidia-api-key"
MODEL_NAME="gpt-oss-120b"
AI_RATE_LIMIT=100

# Bakong Payment Gateway
# Get credentials from: https://api-bakong.nbc.gov.kh
BAKONG_API_URL="https://api-bakong.nbc.gov.kh/v1"
BAKONG_MERCHANT_ID="your_merchant_id"
BAKONG_PHONE_NUMBER="855xxxxxxxxx"
BAKONG_DEVELOPER_TOKEN="your_developer_token"
BAKONG_MERCHANT_NAME="Vibe Survey"
BAKONG_MERCHANT_CITY="Phnom Penh"

# Storage
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES="image/jpeg,image/png,application/pdf"

# CORS
CORS_ORIGINS="http://localhost:3001,http://localhost:3002,http://localhost:3003"

# Logging
LOG_LEVEL="debug"
