# =============================================================================
# Vibe Survey - Backend Environment Variables
# =============================================================================
# This is a template file. Copy this to `.env` and fill in your actual values.
# DO NOT commit `.env` files to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
PORT=3000
NODE_ENV=development

# -----------------------------------------------------------------------------
# Database Configuration (Supabase/PostgreSQL)
# -----------------------------------------------------------------------------
# Uncomment and set your database URL
# DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# Prisma direct connection (for migrations)
# DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# -----------------------------------------------------------------------------
# Supabase Configuration
# -----------------------------------------------------------------------------
# Note: Frontend uses VITE_SUPABASE_URL and VITE_SUPABASE_PUBLISHABLE_KEY
# Backend needs the service role key for admin operations
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------
# Generate a strong random secret (e.g., `openssl rand -base64 32`)
JWT_SECRET=
JWT_REFRESH_SECRET=

# Token expiration times
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# -----------------------------------------------------------------------------
# Encryption & Security
# -----------------------------------------------------------------------------
# Generate a strong encryption key for sensitive data
ENCRYPTION_KEY=

# CORS settings (comma-separated origins)
CORS_ORIGINS=http://localhost:3001,http://localhost:3002,http://localhost:3003

# -----------------------------------------------------------------------------
# Redis / Bull Queue (for background jobs)
# -----------------------------------------------------------------------------
# Uncomment if using Redis for queues
# REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Email Service (SMTP)
# -----------------------------------------------------------------------------
# Uncomment to configure email service
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@vibesurvey.com

# -----------------------------------------------------------------------------
# SMS Service (Twilio)
# -----------------------------------------------------------------------------
# Uncomment for OTP SMS functionality
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# -----------------------------------------------------------------------------
# AI Service Integration
# -----------------------------------------------------------------------------
# OpenAI API key for AI survey builder
# OPENAI_API_KEY=

# Rate limiting for AI endpoints (requests per hour per user)
AI_RATE_LIMIT=100

# -----------------------------------------------------------------------------
# Payment / Mobile Wallet Integration (Cambodia)
# -----------------------------------------------------------------------------
# ABA Pay
# ABA_PAY_MERCHANT_ID=
# ABA_PAY_API_KEY=

# WING
# WING_MERCHANT_ID=
# WING_API_KEY=

# TrueMoney
# TRUEMONEY_MERCHANT_ID=
# TRUEMONEY_API_KEY=

# -----------------------------------------------------------------------------
# File Upload / Storage
# -----------------------------------------------------------------------------
# Max file upload size in bytes (10MB default)
MAX_FILE_SIZE=10485760

# Allowed file types (comma-separated)
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,application/pdf

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Log levels: error, warn, info, debug, verbose
LOG_LEVEL=debug

# Sentry error tracking (optional)
# SENTRY_DSN=
